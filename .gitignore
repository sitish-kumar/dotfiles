# build artifacts (the fork is a submodule; its build is regenerated)
pkgs/hyprtasking/build/
# backups created by the symlink installer
*.bak.*
# logs / caches / state
*.log
__pycache__/
config/**/generated/
# non-portable absolute-path install manifest from the ii base
config/illogical-impulse/installed_listfile
config/illogical-impulse/backups/
# user-specific state and settings — never ship these in updates
config/illogical-impulse/config.json
config/illogical-impulse/installed_true
config/illogical-impulse/migrations.json
config/illogical-impulse/version
config/illogical-impulse/version.json
config/illogical-impulse/actions/
# custom/ lua files are user-owned — seeded once from custom.defaults/ by install.sh,
# never overwritten by git pull. Edit them freely; updates only touch custom.defaults/.
config/hypr/custom/*.lua
config/**/*.bak
config/**/*.bak-*
config/quickshell/ii/_*.qml
config/quickshell/ii/modules/settings/_t.qml

config/hypr/hyprland/colors.lua
config/hypr/hyprlock/colors.conf