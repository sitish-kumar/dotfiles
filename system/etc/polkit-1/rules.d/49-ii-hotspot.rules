// Let members of the `wheel` group start/stop the Wi-Fi hotspot helper without a
// password prompt, so the ii shell's sidebar/settings toggle works from the GUI.
// Scope is tight: it authorizes ONLY pkexec of the exact root-owned helper binary,
// nothing else. The helper itself only touches NetworkManager / create_ap.
polkit.addRule(function (action, subject) {
    if (action.id === "org.freedesktop.policykit.exec" &&
        action.lookup("program") === "/usr/local/bin/ii-hotspot" &&
        subject.local && subject.active && subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
